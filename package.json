{
  "name": "qnd-lab-website",
  "version": "0.0.1.0",
  "description": "千葉大学 量子ナノデバイス研究グループ ホームページ",
  "scripts": {
    "build": "hugo --minify && npx pagefind --site public",
    "dev": "hugo server --disableFastRender",
    "preview": "hugo server --baseURL $CF_PAGES_URL --disableFastRender",
    "build:hugo": "hugo --minify",
    "search:index": "npx pagefind --site public"
  },
  "devDependencies": {
    "pagefind": "^1.3.0",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "autoprefixer": "^10.4.21"
  }
}
